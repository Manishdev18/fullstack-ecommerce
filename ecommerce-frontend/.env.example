# API base URL (include trailing slash to match axios usage)
REACT_APP_API_URL=http://127.0.0.1:8000/

# Canonical site URL for SEO (Open Graph, Twitter cards, JSON-LD). No trailing slash.
# Production example: https://shop.piora.com
REACT_APP_SITE_URL=http://localhost:3000

# Optional: @handle without @ for twitter:site
# REACT_APP_TWITTER_HANDLE=piora

# Google OAuth 2.0 Web client ID (same value as Django GOOGLE_CLIENT_ID)
# Create at https://console.cloud.google.com/apis/credentials — Authorized JavaScript origins: http://localhost:3000
REACT_APP_GOOGLE_CLIENT_ID=
