SECRET_KEY=

ALLOWED_HOSTS=.localhost, .herokuapp.com, .0.0.0.0
DEBUG=True

DJANGO_SETTINGS_MODULE=config.settings.development

# Database (PostgreSQL)
# Option A — Neon / managed (recommended): full URL including database name after the last slash.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require
#
# Option B — separate variables (e.g. docker-compose):
# DB_HOSTNAME: use "db" when Django runs inside docker-compose; use "127.0.0.1" for host Postgres.
# Neon: DB_NAME is the database (often "neondb"), NOT the role name. DB_USERNAME is the role (often "neondb_owner").
# For Neon with DB_* only, sslmode=require is applied automatically when the host contains "neon.tech".
# Override with DB_SSLMODE=disable only for local dev without TLS (not for Neon).
DATABASE_URL=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_HOSTNAME=
DB_PORT=5432
DB_SSLMODE=

# Google Sign-In (server verifies ID tokens). Must match the React app `REACT_APP_GOOGLE_CLIENT_ID` (Web client ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sign-In (server verifies ID tokens; use the same Web client ID as the React app REACT_APP_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=949981528164-peschnlbvkjqsbfr3786q548tio4vmdt.apps.googleusercontent.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
EMAIL_USER=
EMAIL_PASSWORD=

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

BACKEND_DOMAIN=
FRONTEND_DOMAIN=

PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=
STRIPE_WEBHOOK_SECRET=

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Redis
REDIS_BACKEND=redis://redis:6379/0

# NGINX
NGINX_PORT=80
